# PromptFlow Agent Configuration
# Generated by: promptflow-agent pair <code> --server <url>
#
# Location: ~/.promptflow/agent.yaml
# This file is created automatically during pairing and can be edited manually.

# WebSocket URL of the PromptFlow server
server_url: "ws://192.168.2.188:3001/ws/agent"

# Human-readable name for this machine (shown in the dashboard)
machine_name: "my-workstation"

# Authentication token (set during pairing, do not share)
auth_token: ""

# Unique machine identifier (generated during pairing)
machine_uuid: ""

# Root directory for project workspaces
# The agent will only allow sessions within this directory tree.
# Use ~ for home directory (works on Mac and Windows).
workspace_root: "~/projects"

# Maximum number of concurrent Claude CLI sessions on this machine
max_concurrent_sessions: 3

# Logging level: "debug", "info", "warn", "error"
log_level: "info"
